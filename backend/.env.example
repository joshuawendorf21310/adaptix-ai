# Example environment file for backend
# Copy to .env and fill in your values

# Application
ADAPTIX_AI_APP_NAME=adaptix-ai
ADAPTIX_AI_ENV=development
ADAPTIX_AI_DEBUG=false

# Database
ADAPTIX_AI_DATABASE_URL=postgresql://user:password@localhost:5432/adaptix_ai

# Security
ADAPTIX_AI_DEV_SECRET=adaptix-ai-dev-secret
ADAPTIX_AI_ALLOW_DEV_AUTH=true
ADAPTIX_AI_JWT_SECRET=your-secret-key-here-minimum-32-characters

# AWS Configuration
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Bedrock
ADAPTIX_AI_BEDROCK_MODEL_ID=claude-3-5-sonnet-20241022-v2:0
ADAPTIX_AI_BEDROCK_MAX_TOKENS=4096
ADAPTIX_AI_BEDROCK_TEMPERATURE=0.3

# Governance
ADAPTIX_AI_GUARDRAILS_ENABLED=true
ADAPTIX_AI_PII_MASKING_ENABLED=true
ADAPTIX_AI_RATE_LIMIT_PER_MINUTE=100
ADAPTIX_AI_DAILY_TOKEN_BUDGET=1000000

# CORS
ADAPTIX_AI_CORS_ORIGINS=http://localhost:3003

# Optional: Redis
# ADAPTIX_AI_REDIS_ENABLED=false
# ADAPTIX_AI_REDIS_URL=redis://localhost:6379

# Optional: EventBridge
# ADAPTIX_AI_EVENTBRIDGE_ENABLED=false
